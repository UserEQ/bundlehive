{
  "name": "@usereq/bundlehive-build",
  "version": "0.1.1",
  "description": "Vite build preset for BundleHive widgets — lib mode (IIFE + ESM), Tailwind, shadow-DOM-friendly defaults.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UserEQ/bundlehive.git",
    "directory": "packages/build"
  },
  "homepage": "https://github.com/UserEQ/bundlehive#readme",
  "bugs": "https://github.com/UserEQ/bundlehive/issues",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.3",
    "tailwindcss": "^4.2.3",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}

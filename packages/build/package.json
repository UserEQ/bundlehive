{
  "name": "@bundlehive/build",
  "version": "0.0.0",
  "description": "Vite build preset for BundleHive widgets — lib mode (IIFE + ESM), Tailwind, shadow-DOM-friendly defaults.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.3",
    "tailwindcss": "^4.2.3",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}

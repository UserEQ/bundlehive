{
  "name": "bundlehive-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun --filter './packages/*' build",
    "build:examples": "bun --filter './examples/*' build",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
